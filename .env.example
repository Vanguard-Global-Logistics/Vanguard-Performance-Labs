# Vanguard Performance Labs — env example
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Jessie live AI concierge (server-side only — never exposed to the client).
# Without this, Jessie gracefully falls back to scripted routing.
ANTHROPIC_API_KEY=

# Wire /api/inquiry to one of these (owner TODO):
# RESEND_API_KEY=
# HUBSPOT_TOKEN=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Order management ──────────────────────────────────────────
# Persistence (production): Supabase project + run supabase/orders.sql once.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Customer emails (Resend). Without it, emails no-op and log (dev).
RESEND_API_KEY=
ORDER_EMAIL_FROM="Vanguard Performance Labs <orders@yourdomain.com>"
# Owner order board at /admin. REQUIRED for admin to work at all.
ADMIN_TOKEN=
# Released-to-shipping webhook (Zapier/Make -> ShipStation/Shippo/etc). Optional.
SHIPPING_WEBHOOK_URL=
# Will-call pickup details shown in the confirmation email.
WILLCALL_ADDRESS="Vanguard Performance Labs, <street>, <city ST zip> — Mon-Fri 9-4"
# Phone shown to customers choosing pay-by-phone.
PAYMENT_PHONE=

# ── Owner alerts on new orders ────────────────────────────────
OWNER_EMAIL=            # pick-list email on every order
# SMS via Twilio (optional; without it SMS no-ops and logs)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=            # your Twilio number, E.164 e.g. +15551234567
OWNER_PHONE=            # your mobile, E.164
